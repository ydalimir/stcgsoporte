
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return request.auth != null && getUserData(request.auth.uid).role == 'admin';
    }

    function hasPermission(module) {
      let permissions = getUserData(request.auth.uid).permissions;
      return request.auth != null 
             && permissions != null
             && module in permissions;
    }
    
    match /users/{userId} {
      allow list, read, write: if isAdmin();
      allow get: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;
    }

    function canRead(module) {
      return isAdmin() || hasPermission(module);
    }
    
    match /projects/{projectId} {
      allow create: if (hasPermission('projects') || isAdmin()) && request.resource.data.userId == request.auth.uid;
      allow list: if canRead('projects');
      allow get: if isAdmin() || get(/databases/$(database)/documents/projects/$(projectId)).data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }

    match /tickets/{ticketId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow list: if canRead('tickets');
      allow get: if isAdmin() || get(/databases/$(database)/documents/tickets/$(ticketId)).data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }

    match /quotes/{quoteId} {
      allow create: if (hasPermission('quotes') || isAdmin()) && request.resource.data.userId == request.auth.uid;
      allow list: if canRead('quotes');
      allow get: if isAdmin() || get(/databases/$(database)/documents/quotes/$(quoteId)).data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }
    
    match /purchase_orders/{orderId} {
      allow create: if (hasPermission('purchase_orders') || isAdmin()) && request.resource.data.userId == request.auth.uid;
      allow list: if canRead('purchase_orders');
      allow get: if isAdmin() || get(/databases/$(database)/documents/purchase_orders/$(orderId)).data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || resource.data.userId == request.auth.uid;
    }

    // Publicly readable collections
    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
     match /services {
      allow list: if true;
    }

    match /spare_parts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /spare_parts {
      allow list: if true;
    }

    // Restricted collections
    match /clients/{docId} {
      allow read: if canRead('clients');
      allow write: if isAdmin();
    }
    match /clients {
        allow list: if canRead('clients');
    }
    
    match /suppliers/{docId} {
      allow read: if canRead('suppliers');
      allow write: if isAdmin();
    }
     match /suppliers {
      allow list: if canRead('suppliers');
    }

    match /counters/{counterId} {
        allow read, write: if isAdmin();
    }
  }
}
