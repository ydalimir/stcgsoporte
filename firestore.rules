
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isAdmin() {
      return request.auth != null && getUserData(request.auth.uid).role == 'admin';
    }

    function hasPermission(module) {
      // Check if the user document and permissions field exist, and if the module is in the permissions list.
      let permissions = getUserData(request.auth.uid).permissions;
      return request.auth != null 
             && permissions != null
             && module in permissions;
    }
    
    match /users/{userId} {
      // Admins can manage all users.
      allow list, read, write: if isAdmin();
      
      // A user can read their own profile.
      allow get: if request.auth.uid == userId;

      // A user can update their own document, but CANNOT change their role.
      allow update: if request.auth.uid == userId && request.resource.data.role == resource.data.role;
    }

    function canRead(module) {
      // Helper to check if user is admin OR has specific read permission
      return isAdmin() || hasPermission(module);
    }
    
    match /projects/{docId} {
      allow read: if canRead('projects');
      allow write: if isAdmin();
    }
     match /projects {
      allow list: if canRead('projects');
    }

    match /tickets/{docId} {
      allow create: if request.auth != null; 
      allow read: if canRead('tickets');
      allow write: if isAdmin();
    }
    match /tickets {
       allow list: if canRead('tickets');
    }

    match /services/{docId} {
      allow read: if canRead('services');
      allow write: if isAdmin();
    }
     match /services {
      allow list: if canRead('services');
    }

    match /quotes/{docId} {
        allow read: if canRead('quotes');
        allow write: if isAdmin();
    }
    match /quotes {
        allow list: if canRead('quotes');
    }
    
    match /clients/{docId} {
      allow read: if canRead('clients');
      allow write: if isAdmin();
    }
    match /clients {
        allow list: if canRead('clients');
    }

    match /spare_parts/{docId} {
      allow read: if canRead('spare_parts');
      allow write: if isAdmin();
    }
    match /spare_parts {
      allow list: if canRead('spare_parts');
    }
    
    match /suppliers/{docId} {
      allow read: if canRead('suppliers');
      allow write: if isAdmin();
    }
     match /suppliers {
      allow list: if canRead('suppliers');
    }

    match /purchase_orders/{orderId} {
        allow read: if canRead('purchase_orders');
        allow write: if isAdmin();
    }
     match /purchase_orders {
        allow list: if canRead('purchase_orders');
    }

    match /counters/{counterId} {
        allow read, write: if isAdmin();
    }
  }
}
